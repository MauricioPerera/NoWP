# ── Database ───────────────────────────────────────────
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=chimera_nowp
DB_USERNAME=root
DB_PASSWORD=

# ── Application ───────────────────────────────────────
APP_NAME="Chimera NoWP"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# ── JWT Authentication ─────────────────────────────────
JWT_SECRET=your-secret-key-here-generate-a-random-string
JWT_EXPIRATION=3600

# ── Cache ──────────────────────────────────────────────
CACHE_DRIVER=auto
CACHE_PREFIX=chimera_

# ── File Upload ────────────────────────────────────────
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# ── Locale ─────────────────────────────────────────────
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,fr

# ── Security ───────────────────────────────────────────
RATE_LIMIT_MAX_ATTEMPTS=60
RATE_LIMIT_DECAY_SECONDS=60

# ── Agent Engine ───────────────────────────────────────
AGENT_ENABLED=true
AGENT_PROVIDER=ollama
# Options: ollama, cloudflare, openrouter, openai
AGENT_MAX_ITERATIONS=25

# ── Ollama (local, free) ──────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Cloudflare Workers AI (cloud, free tier) ──────────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_AI_MODEL=@cf/ibm-granite/granite-4.0-h-micro

# ── OpenRouter (200+ models) ──────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nousresearch/hermes-4-scout

# ── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Search & Memory Embeddings ─────────────────────────
# Provider: cloudflare | ollama | openai | custom
SEARCH_PROVIDER=cloudflare
# Cloudflare EmbeddingGemma (usa las mismas credenciales CF de arriba)
CF_EMBED_MODEL=@cf/google/embeddinggemma-300m
CF_EMBED_DIMS=768
# Matryoshka truncation: 384 = 3 etapas simetricas [128, 256, 384]
SEARCH_DIMENSIONS=384
# Alternativa Ollama local:
# SEARCH_PROVIDER=ollama
# OLLAMA_EMBED_MODEL=embeddinggemma
