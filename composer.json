{
    "name": "mauricioperera/chimera-nowp",
    "description": "Agentic CMS - Chimera AI engine + NoWP CMS framework fused into one",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "firebase/php-jwt": "^6.10",
        "intervention/image": "^3.0",
        "mauricioperera/php-vector-store": "^0.1"
    },
    "suggest": {
        "mauricioperera/php-agent-memory": "Enhanced persistent memory with vector deduplication",
        "mauricioperera/php-agent-shell": "CLI command discovery tools for agent",
        "mauricioperera/php-a2e": "A2E workflow automation engine"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "ChimeraNoWP\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage"
    }
}
