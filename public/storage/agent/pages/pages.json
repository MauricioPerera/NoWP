    "tickets-new": {
        "slug": "tickets-new",
        "title": "New Ticket",
        "description": "",
        "template": "form-page",
        "layout": "admin-sidebar",
        "sections": [
            {
                "slot": "header",
                "component": "heading",
                "props": {
                    "content": "Create Ticket",
                    "level": 1
                }
            },
            {
                "slot": "main",
                "component": "form",
                "props": {
                    "action": "/api/entities/ticket",
                    "method": "POST",
                    "fields": [
                        {
                            "name": "subject",
                            "type": "text",
                            "label": "Subject",
                            "required": true
                        },
                        {
                            "name": "customer_email",
                            "type": "email",
                            "label": "Customer Email",
                            "required": true
                        },
                        {
                            "name": "priority",
                            "type": "select",
                            "label": "Priority",
                            "options": [
                                "low",
                                "medium",
                                "high"
                            ],
                            "required": true
                        },
                        {
                            "name": "status",
                            "type": "select",
                            "label": "Status",
                            "options": [
                                "open",
                                "in_progress",
                                "resolved",
                                "closed"
                            ]
                        },
                        {
                            "name": "description",
                            "type": "textarea",
                            "label": "Description"
                        }
                    ],
                    "submit": "Create Ticket",
                    "redirect": "/tickets"
                }
            }
        ],
        "auth": {
            "required": true
