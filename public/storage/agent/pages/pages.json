    "ticket-detail": {
        "slug": "ticket-detail",
        "title": "Ticket #{{id}}",
        "description": "",
        "template": "detail-page",
        "layout": "admin-sidebar",
        "sections": [
            {
                "slot": "header",
                "component": "heading",
                "props": {
                    "content": "Ticket #{{id}}"
                }
            },
            {
                "slot": "actions",
                "component": "button-group",
                "props": {
                    "buttons": [
                        {
                            "label": "Edit",
                            "action": "navigate",
                            "to": "/ticket-edit?id={{id}}",
                            "variant": "primary"
                        },
                        {
                            "label": "Back to List",
                            "action": "navigate",
                            "to": "/tickets"
                        }
                    ]
                }
            },
            {
                "slot": "main",
                "component": "detail-view",
                "props": {
                    "source": {
                        "tool": "entity_find",
                        "args": {
                            "entity": "ticket",
                            "id": "{{id}}"
                        }
                    },
                    "fields": [
                        "id",
                        "subject",
                        "priority",
                        "status",
                        "description",
                        "customer_email",
                        "created_at",
                        "updated_at"
                    ]
                }
            }
        ],
        "auth": {
            "required": true
        },
        "nav": null,
        "created_at": "2026-03-22T17:48:55+01:00"
    },
    "ticket-edit": {
        "slug": "ticket-edit",
        "title": "Edit Ticket #{{id}}",
        "description": "",
        "template": "form-page",
        "layout": "admin-sidebar",
        "sections": [
            {
                "slot": "header",
                "component": "heading",
                "props": {
                    "content": "Edit Ticket #{{id}}"
                }
            },
            {
                "slot": "main",
                "component": "form",
                "props": {
                    "source": {
                        "tool": "entity_find",
                        "args": {
                            "entity": "ticket",
                            "id": "{{id}}"
                        }
                    },
                    "action": "/api/entities/ticket/{{id}}",
                    "method": "PUT",
                    "fields": [
                        {
                            "name": "subject",
                            "type": "text",
                            "label": "Subject",
                            "required": true
                        },
                        {
                            "name": "customer_email",
                            "type": "email",
                            "label": "Customer Email",
                            "required": true
                        },
                        {
                            "name": "priority",
                            "type": "select",
                            "label": "Priority",
                            "options": [
                                "low",
                                "medium",
                                "high"
                            ],
                            "required": true
                        },
                        {
                            "name": "status",
                            "type": "select",
                            "label": "Status",
                            "options": [
                                "open",
                                "in_progress",
                                "resolved",
                                "closed"
                            ]
                        },
                        {
                            "name": "description",
                            "type": "textarea",
                            "label": "Description"
                        }
                    ],
                    "submit": "Save Changes",
                    "redirect": "/ticket-detail?id={{id}}"
                }
            }
        ],
        "auth": {
            "required": true
        },
        "nav": null,
        "created_at": "2026-03-22T17:49:28+01:00"
    },
